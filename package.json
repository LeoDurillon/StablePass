        "bun-plugin-tailwind": "0.1.2"
      },
      "dev": {
        "@types/bun": "latest",
        "@types/react": "19.2.5",
        "@types/react-dom": "19.2.3",
        "@types/firefox-webext-browser": "143.0.0",
        "@types/chrome": "0.1.40",
        "typescript": "6.0.3"
      },
      "test": {
        "@happy-dom/global-registrator": "20.9.0"
      }
    }
  },
  "devDependencies": {
    "@types/bun": "catalog:dev",
    "oxfmt": "catalog:tools",
