{
  "manifest_version": 2,
  "name": "Stable Pass (debug)",
  "author": "Leo Durillon",
  "version": "1.0",
  "description": "",
  "icons": {
    "48": "icon.png"
  },
  "permissions": ["storage", "activeTab"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["index.js"]
    }
  ],
  "page_action": {
    "browser_style": true,
    "show_matches": ["<all_urls>"],
    "default_icon": "icon.png",
    "default_title": "Stable Pass",
    "default_popup": "./popup/index.html"
  }
}
